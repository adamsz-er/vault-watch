  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adamsz-er/vault-watch.git",
    "directory": "vault-watch-chrome"
  },
  "bugs": {
    "url": "https://github.com/adamsz-er/vault-watch/issues"
  },
  "homepage": "https://github.com/adamsz-er/vault-watch#readme",
  "devDependencies": {
    "@types/chrome": "^0.1.40",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  }
